# Template for .b.env — arm B of the proposer-policy A/B experiment.
# Copy to .b.env (gitignored) and fill in any per-arm overrides.
#
# Arm B is the TREATMENT: the source-first find_considerations prompt.
# It instructs the proposer to inspect loaded sources before proposing
# considerations, and to call web_research / ingest first when under-sourced.

FIND_CONSIDERATIONS_VARIANT=source_first

