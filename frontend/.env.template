# Copy to frontend/.env and fill in any secrets.
# Local overrides (per-worktree ports, individual dev preferences, etc.) go in
# frontend/.env.overrides, which is .gitignored and sourced on top of
# frontend/.env by scripts/with-env-overrides.sh (wired into package.json).

# Backend API URL (the Next.js middleware proxies /api/* here).
# In a workmux worktree these are auto-derived from the offset and live in
# frontend/.env.overrides.
NEXT_PUBLIC_API_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000

# Skip the invite-password gate AND the Supabase session check. The backend
# must match (set AUTH_ENABLED=0 in your root .env) or /api calls will 401.
AUTH_ENABLED=0

# Admin status (traces, statistics, ab-evals) is stored in the database;
# the middleware reads it via /api/auth/me. Manage admins with
# `scripts/grant_admin.py` from the repo root.

# HMAC key for signing the invite cookie. Only consulted when AUTH_ENABLED=1.
# A dummy value is fine for local dev; use a 32+ char random string in prod.
INVITE_SECRET=dev-only-dummy-do-not-use-in-prod

# --- Only needed if you want to exercise the real auth flow (AUTH_ENABLED unset/1) ---

# Password the /welcome page accepts.
# INVITE_PASSWORD=

# Supabase project credentials. Locally these come from `supabase start`
# output; for production use the deployed project's values.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
